{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ES2022",
		"moduleResolution": "Node",
		"strict": true,
		"jsx": "react-jsx",
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"resolveJsonModule": true,
		"types": ["vitest", "@testing-library/jest-dom"]
	},
	"include": ["src", "types", "vitest.setup.ts"],
	"exclude": ["dist", "node_modules"]
}
