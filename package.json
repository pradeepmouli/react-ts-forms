{
	"name": "@mouli.dev/react-ts-forms",
	"version": "1.0.0",
	"private": false,
	"type": "module",
	"license": "MIT",
	"exports": {
		"./package.json": "./package.json",
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./vite": {
			"types": "./dist/vite-plugin/index.d.ts",
			"import": "./dist/vite-plugin/index.js"
		}
	},
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"files": [
		"dist"
	],
	"scripts": {
		"clean": "rimraf dist",
		"build": "tsc --project tsconfig.build.json",
		"dev": "tsx watch ./src/index.ts",
		"test": "vitest run",
		"test:watch": "vitest watch",
		"lint": "oxlint .",
		"format": "oxfmt .",
		"storybook": "storybook dev -p 6006",
		"build:storybook": "storybook build",
		"size": "size-limit",
		"prepublishOnly": "pnpm run build && pnpm run test && pnpm run size"
	},
	"size-limit": [
		{
			"path": "dist/index.js",
			"limit": "15 KB"
		}
	],
	"peerDependencies": {
		"react": ">=18",
		"react-dom": ">=18"
	},
	"devDependencies": {
		"@rollup/pluginutils": "^5.3.0",
		"@storybook/addon-essentials": "^8.1.0",
		"@storybook/addon-interactions": "^8.1.0",
		"@storybook/react": "^8.1.0",
		"@storybook/react-vite": "^8.1.0",
		"@storybook/test": "^8.1.0",
		"@testing-library/jest-dom": "^6.4.0",
		"@testing-library/react": "^14.1.2",
		"@types/node": "^24.10.1",
		"@types/react": "^18.2.38",
		"@types/react-dom": "^18.2.17",
		"@vitejs/plugin-react": "^4.3.0",
		"axe-core": "^4.9.0",
		"jsdom": "^24.0.0",
		"oxfmt": "^0.1.0",
		"oxlint": "^0.3.4",
		"pino": "^9.0.0",
		"react": "^18.3.1",
		"react-dom": "^18.3.1",
		"rimraf": "^5.0.5",
		"size-limit": "^11.0.0",
		"storybook": "^8.1.0",
		"tslib": "^2.6.2",
		"tsx": "^4.16.0",
		"typescript": "^5.6.3",
		"vite": "^5.2.0",
		"vitest": "^1.5.0"
	},
	"engines": {
		"node": ">=18"
	}
}
